{
	"name": "file-delivery-locker-worker",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev",
		"next:build": "next build",
		"build": "node scripts/build.mjs",
		"start": "next start",
		"lint": "next lint",
		"cf:prepare": "node scripts/prepare-cloudflare-deploy.mjs",
		"deploy": "node scripts/prepare-cloudflare-deploy.mjs && opennextjs-cloudflare build -c .wrangler/deploy-wrangler.jsonc && opennextjs-cloudflare deploy -c .wrangler/deploy-wrangler.jsonc",
		"upload": "node scripts/prepare-cloudflare-deploy.mjs && opennextjs-cloudflare build -c .wrangler/deploy-wrangler.jsonc && opennextjs-cloudflare upload -c .wrangler/deploy-wrangler.jsonc",
		"preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
		"cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts"
	},
	"dependencies": {
		"@cap.js/server": "^4.0.5",
		"@opennextjs/cloudflare": "^1.19.8",
		"cap-widget": "^0.1.50",
		"goey-toast": "^0.4.0",
		"next": "16.2.5",
		"react": "^19.1.7",
		"react-dom": "^19.1.7"
	},
	"devDependencies": {
		"@eslint/eslintrc": "^3",
		"@tailwindcss/postcss": "^4",
		"@types/node": "^25.6.2",
		"@types/react": "^19.1.7",
		"@types/react-dom": "^19.1.7",
		"eslint": "^9",
		"eslint-config-next": "16.2.5",
		"tailwindcss": "^4",
		"typescript": "^5.7.4",
		"wrangler": "^4.90.0"
	}
}
